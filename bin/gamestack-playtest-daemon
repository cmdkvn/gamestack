#!/usr/bin/env bash
# gamestack-playtest-daemon — broker between Claude Code and a running engine build
#
# Loads a scenario JSON, connects to the gamestack engine SDK (Unity port 7331,
# Godot port 7332), executes setup → steps → teardown, and writes a run log.
# Exits non-zero on any failed assertion or timeout.
#
# Wraps the same workflow as the interactive /playtest skill — useful when you
# want to script the playtest from CI or as a long-running background process.
set -euo pipefail

if ! command -v bun >/dev/null 2>&1; then
  echo "error: bun is required for gamestack CLIs." >&2
  echo "  install:  brew install bun  (or see https://bun.sh)" >&2
  exit 127
fi

# Resolve symlinks so the shim works when invoked via a symlink in PATH.
_GS_SOURCE="${BASH_SOURCE[0]}"
while [ -L "$_GS_SOURCE" ]; do
  _GS_DIR="$(cd "$(dirname "$_GS_SOURCE")" && pwd)"
  _GS_TARGET="$(readlink "$_GS_SOURCE")"
  case "$_GS_TARGET" in
    /*) _GS_SOURCE="$_GS_TARGET" ;;
    *)  _GS_SOURCE="$_GS_DIR/$_GS_TARGET" ;;
  esac
done
GAMESTACK_BIN_DIR="$(cd "$(dirname "$_GS_SOURCE")" && pwd)"
exec bun run "$GAMESTACK_BIN_DIR/impl/playtest-daemon/index.ts" "$@"
