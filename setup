#!/usr/bin/env bash
# gamestack — install AI agent skills for game development
#
# Usage:
#   ./setup                        Install for the auto-detected host (Claude Code if present).
#   ./setup --host <name>          Install for a specific host.
#   ./setup --status               Show what's currently installed.
#   ./setup --uninstall            Remove gamestack symlinks for the detected host.
#   ./setup -h | --help            Show this help.
#
# Supported hosts (v0.1):
#   claude-code  — auto-detected when ~/.claude/ exists.
#
# Planned hosts (post-v1): codex, opencode, cursor, factory, slate, kiro, hermes, gbrain.

set -euo pipefail

GAMESTACK_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export GAMESTACK_DIR

HOST=""
MODE="install"
# SELECT_SKILLS / SELECT_CLI track explicit user opt-in. If neither is set
# after parsing, we install / uninstall / status BOTH (the default).
SELECT_SKILLS=0
SELECT_CLI=0
CLI_DIR=""

usage() {
  cat <<'EOF'
Usage: ./setup [--host <name>] [--skills | --cli] [--cli-dir <path>] [--uninstall | --status]

Install gamestack skills AND CLIs by default. Use --skills or --cli to scope
to one or the other.

Options:
  --host <name>      Override host detection.
                     Supported: claude-code, codex, opencode, cursor, factory,
                     slate, kiro, hermes, gbrain
  --skills           Operate on skills only. Skip CLI install/uninstall/status.
  --cli              Operate on CLIs only. Skip skill install/uninstall/status.
                     (Pass both --skills and --cli to be explicit; same as
                     neither.)
  --cli-dir <path>   Override the CLI install directory. Auto-detects
                     /opt/homebrew/bin, /usr/local/bin, or ~/.local/bin
                     otherwise.
  --uninstall        Remove gamestack symlinks (scoped by --skills/--cli).
  --status           Show install status without changing anything (scoped by
                     --skills/--cli).
  --check-updates    Compare local gamestack commit to origin/main.
                     Local-only — no third-party network calls.
  -h, --help         Show this help.

Examples:
  ./setup                           # install skills + CLIs (default)
  ./setup --skills                  # install skills only
  ./setup --cli                     # install CLIs only
  ./setup --cli-dir=~/bin           # install both; CLIs go to ~/bin
  ./setup --status                  # show skills + CLI status
  ./setup --status --cli            # show CLI status only
  ./setup --uninstall --skills      # remove skills, leave CLIs in place
  ./setup --uninstall               # remove both

After developing changes in this checkout, re-run `./setup` to re-link
anything new and clean up stale symlinks from removals.

EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help)
      usage
      exit 0
      ;;
    --host)
      if [[ $# -lt 2 ]]; then
        echo "error: --host requires a value" >&2
        exit 1
      fi
      HOST="$2"
      shift 2
      ;;
    --host=*)
      HOST="${1#*=}"
      shift
      ;;
    --uninstall)
      MODE="uninstall"
      shift
      ;;
    --status)
      MODE="status"
      shift
      ;;
    --check-updates)
      MODE="check-updates"
      shift
      ;;
    --skills)
      SELECT_SKILLS=1
      shift
      ;;
    --cli)
      SELECT_CLI=1
      shift
      ;;
    --with-cli)
      # Back-compat alias from the previous release. CLIs are part of the
      # default now, so this is a silent no-op. Removed in a future release.
      shift
      ;;
    --cli-dir)
      if [[ $# -lt 2 ]]; then
        echo "error: --cli-dir requires a value" >&2
        exit 1
      fi
      CLI_DIR="$2"
      shift 2
      ;;
    --cli-dir=*)
      CLI_DIR="${1#*=}"
      shift
      ;;
    *)
      echo "error: unknown argument: $1" >&2
      usage >&2
      exit 1
      ;;
  esac
done

# If the user didn't scope to one side, do both. This is the default behavior.
if [[ $SELECT_SKILLS -eq 0 && $SELECT_CLI -eq 0 ]]; then
  SELECT_SKILLS=1
  SELECT_CLI=1
fi

if [[ "$MODE" == "check-updates" ]]; then
  # Local-only drift check: compare the current commit to origin/main.
  # No network call unless the developer has already configured a remote.
  if ! git -C "$GAMESTACK_DIR" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    echo "error: $GAMESTACK_DIR is not a git checkout — can't compute drift." >&2
    exit 1
  fi
  current="$(git -C "$GAMESTACK_DIR" rev-parse --short HEAD)"
  version="$(cat "$GAMESTACK_DIR/VERSION" 2>/dev/null | tr -d '[:space:]')"
  echo "Local gamestack:  v${version:-unknown} @ ${current}"

  if git -C "$GAMESTACK_DIR" rev-parse --verify origin/main >/dev/null 2>&1; then
    if git -C "$GAMESTACK_DIR" fetch --quiet origin main 2>/dev/null; then
      remote="$(git -C "$GAMESTACK_DIR" rev-parse --short origin/main)"
      behind="$(git -C "$GAMESTACK_DIR" rev-list --count HEAD..origin/main 2>/dev/null || echo "?")"
      ahead="$(git -C "$GAMESTACK_DIR" rev-list --count origin/main..HEAD 2>/dev/null || echo "?")"
      echo "Remote main:      @ ${remote}"
      if [[ "$current" == "$remote" ]]; then
        echo "Status:           up to date"
      else
        echo "Status:           ${behind} commit(s) behind, ${ahead} commit(s) ahead"
        echo
        echo "To update: git -C \"$GAMESTACK_DIR\" pull --ff-only"
      fi
    else
      echo "Status:           offline — couldn't fetch origin/main (skipping remote comparison)"
    fi
  else
    echo "Status:           no origin/main remote configured — skipping remote comparison"
  fi
  exit 0
fi

# Auto-detect host if not specified.
if [[ -z "$HOST" ]]; then
  if [[ -d "$HOME/.claude" ]]; then
    HOST="claude-code"
  else
    echo "error: no host detected." >&2
    echo "  Specify a host: --host <name>" >&2
    echo "  Supported in v0.1: claude-code" >&2
    exit 1
  fi
fi

if [[ "$HOST" == _* ]]; then
  echo "error: host names starting with underscore are reserved for internal use" >&2
  exit 1
fi

HOST_SCRIPT="$GAMESTACK_DIR/hosts/${HOST}.sh"
if [[ ! -f "$HOST_SCRIPT" ]]; then
  available=$(find "$GAMESTACK_DIR/hosts" -maxdepth 1 -name "*.sh" ! -name '_*' -exec basename {} .sh \; 2>/dev/null | sort | tr '\n' ' ')
  echo "error: unsupported host '$HOST'" >&2
  echo "  Available host scripts: ${available:-(none)}" >&2
  exit 1
fi

# Validate dependencies the host scripts assume are present.
for cmd in git ln find basename; do
  if ! command -v "$cmd" >/dev/null 2>&1; then
    echo "error: missing required command: $cmd" >&2
    exit 1
  fi
done

# Load the host's implementation.
# shellcheck source=/dev/null
source "$HOST_SCRIPT"

# Each host script must define: gamestack_install, gamestack_uninstall, gamestack_status.
for fn in gamestack_install gamestack_uninstall gamestack_status; do
  if ! declare -f "$fn" >/dev/null; then
    echo "error: host script $HOST_SCRIPT does not define $fn" >&2
    exit 1
  fi
done

if [[ $SELECT_CLI -eq 1 && -z "$CLI_DIR" ]]; then
  CLI_DIR="$(_gamestack_detect_cli_dir)"
fi
# Expand a leading ~ in CLI_DIR (bash doesn't tilde-expand inside variables).
if [[ -n "$CLI_DIR" && "$CLI_DIR" == "~"* ]]; then
  CLI_DIR="${HOME}${CLI_DIR:1}"
fi

case "$MODE" in
  install)
    if [[ $SELECT_SKILLS -eq 1 ]]; then
      echo "==> Installing gamestack skills for $HOST..."
      gamestack_install
    fi
    if [[ $SELECT_CLI -eq 1 ]]; then
      [[ $SELECT_SKILLS -eq 1 ]] && echo
      echo "==> Installing gamestack CLIs..."
      _gamestack_install_clis_to "$CLI_DIR"
    fi
    ;;
  uninstall)
    if [[ $SELECT_SKILLS -eq 1 ]]; then
      echo "==> Uninstalling gamestack skills for $HOST..."
      gamestack_uninstall
    fi
    if [[ $SELECT_CLI -eq 1 ]]; then
      [[ $SELECT_SKILLS -eq 1 ]] && echo
      echo "==> Uninstalling gamestack CLIs..."
      _gamestack_uninstall_clis_to "$CLI_DIR"
    fi
    ;;
  status)
    if [[ $SELECT_SKILLS -eq 1 ]]; then
      echo "==> gamestack status for $HOST:"
      gamestack_status
    fi
    if [[ $SELECT_CLI -eq 1 ]]; then
      [[ $SELECT_SKILLS -eq 1 ]] && echo
      echo "==> gamestack CLI status:"
      _gamestack_status_clis_to "$CLI_DIR"
    fi
    ;;
esac
