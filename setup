#!/usr/bin/env bash
# gamestack — install AI agent skills for game development
#
# Usage:
#   ./setup                        Install for the auto-detected host (Claude Code if present).
#   ./setup --host <name>          Install for a specific host.
#   ./setup --status               Show what's currently installed.
#   ./setup --uninstall            Remove gamestack symlinks for the detected host.
#   ./setup -h | --help            Show this help.
#
# Supported hosts (v0.1):
#   claude-code  — auto-detected when ~/.claude/ exists.
#
# Planned hosts (post-v1): codex, opencode, cursor, factory, slate, kiro, hermes, gbrain.

set -euo pipefail

GAMESTACK_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export GAMESTACK_DIR

HOST=""
MODE="install"
# SELECT_SKILLS / SELECT_CLI track explicit user opt-in. If neither is set
# after parsing, we install / uninstall / status BOTH (the default).
SELECT_SKILLS=0
SELECT_CLI=0
CLI_DIR=""
HOOKS_FOR=""

usage() {
  cat <<'EOF'
Usage: ./setup [--host <name>] [--skills | --cli] [--cli-dir <path>] [--uninstall | --status]

Install gamestack skills AND CLIs by default. Use --skills or --cli to scope
to one or the other.

Options:
  --host <name>      Override host detection.
                     Supported: claude-code, codex, opencode, cursor, factory,
                     slate, kiro, hermes, gbrain
  --skills           Operate on skills only. Skip CLI install/uninstall/status.
  --cli              Operate on CLIs only. Skip skill install/uninstall/status.
                     (Pass both --skills and --cli to be explicit; same as
                     neither.)
  --cli-dir <path>   Override the CLI install directory. Auto-detects
                     /opt/homebrew/bin, /usr/local/bin, or ~/.local/bin
                     otherwise.
  --hooks-for <path> Install end-user hooks (session-start, validate-state)
                     into <path>/.claude/settings.local.json. Symlinks the
                     hook scripts into the CLI dir. Requires jq.
  --uninstall        Remove gamestack symlinks (scoped by --skills/--cli).
  --status           Show install status without changing anything (scoped by
                     --skills/--cli).
  --check-updates    Compare local gamestack commit to origin/main.
                     Local-only — no third-party network calls.
  -h, --help         Show this help.

Examples:
  ./setup                           # install skills + CLIs (default)
  ./setup --skills                  # install skills only
  ./setup --cli                     # install CLIs only
  ./setup --cli-dir=~/bin           # install both; CLIs go to ~/bin
  ./setup --status                  # show skills + CLI status
  ./setup --status --cli            # show CLI status only
  ./setup --uninstall --skills      # remove skills, leave CLIs in place
  ./setup --uninstall               # remove both
  ./setup --hooks-for ~/mygame      # install hooks into a project (CLIs auto-link)

./setup is idempotent. Re-run it any time (for example after `git pull`)
to sync ~/.claude with this checkout. It detects drift, prints what will
change, and exits with "Already in sync" when there is nothing to do.

EOF
}

# Render a planner TSV section under a heading, e.g. "Skills" / "CLIs".
# Lines are read from stdin in the TSV schema:
#   add\t<name>
#   stale\t<basename>\t<dead_target>
#   conflict\t<name>\t<reason>
#   skip\t<name>\t<reason>
#   remove\t<name>
# Prints nothing if there are no lines.
_gamestack_render_plan_section() {
  local heading="$1"
  local input
  input="$(cat)"
  if [[ -z "$input" ]]; then
    return 0
  fi
  echo "  $heading:"
  while IFS=$'\t' read -r action name extra; do
    case "$action" in
      add)
        printf '    + %s\n' "$name"
        ;;
      remove)
        printf '    - %s\n' "$name"
        ;;
      stale)
        printf '    - %s   (stale symlink)\n' "$name"
        ;;
      conflict)
        printf '    ! %s   (conflict — %s; skipping)\n' "$name" "$extra"
        ;;
      skip)
        printf '    · %s   (%s)\n' "$name" "$extra"
        ;;
    esac
  done <<<"$input"
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help)
      usage
      exit 0
      ;;
    --host)
      if [[ $# -lt 2 ]]; then
        echo "error: --host requires a value" >&2
        exit 1
      fi
      HOST="$2"
      shift 2
      ;;
    --host=*)
      HOST="${1#*=}"
      shift
      ;;
    --uninstall)
      MODE="uninstall"
      shift
      ;;
    --status)
      MODE="status"
      shift
      ;;
    --check-updates)
      MODE="check-updates"
      shift
      ;;
    --skills)
      SELECT_SKILLS=1
      shift
      ;;
    --cli)
      SELECT_CLI=1
      shift
      ;;
    --with-cli)
      # Back-compat alias from the previous release. CLIs are part of the
      # default now, so this is a silent no-op. Removed in a future release.
      shift
      ;;
    --cli-dir)
      if [[ $# -lt 2 ]]; then
        echo "error: --cli-dir requires a value" >&2
        exit 1
      fi
      CLI_DIR="$2"
      shift 2
      ;;
    --cli-dir=*)
      CLI_DIR="${1#*=}"
      shift
      ;;
    --hooks-for)
      if [[ $# -lt 2 ]]; then
        echo "error: --hooks-for requires a value" >&2
        exit 1
      fi
      HOOKS_FOR="$2"
      shift 2
      ;;
    --hooks-for=*)
      HOOKS_FOR="${1#*=}"
      shift
      ;;
    *)
      echo "error: unknown argument: $1" >&2
      usage >&2
      exit 1
      ;;
  esac
done

# If the user didn't scope to one side, do both. This is the default behavior.
if [[ $SELECT_SKILLS -eq 0 && $SELECT_CLI -eq 0 ]]; then
  SELECT_SKILLS=1
  SELECT_CLI=1
fi

if [[ "$MODE" == "check-updates" ]]; then
  # Local-only drift check: compare the current commit to origin/main.
  # No network call unless the developer has already configured a remote.
  if ! git -C "$GAMESTACK_DIR" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    echo "error: $GAMESTACK_DIR is not a git checkout — can't compute drift." >&2
    exit 1
  fi
  current="$(git -C "$GAMESTACK_DIR" rev-parse --short HEAD)"
  version="$(tr -d '[:space:]' < "$GAMESTACK_DIR/VERSION" 2>/dev/null)"
  echo "Local gamestack:  v${version:-unknown} @ ${current}"

  if git -C "$GAMESTACK_DIR" rev-parse --verify origin/main >/dev/null 2>&1; then
    if git -C "$GAMESTACK_DIR" fetch --quiet origin main 2>/dev/null; then
      remote="$(git -C "$GAMESTACK_DIR" rev-parse --short origin/main)"
      behind="$(git -C "$GAMESTACK_DIR" rev-list --count HEAD..origin/main 2>/dev/null || echo "?")"
      ahead="$(git -C "$GAMESTACK_DIR" rev-list --count origin/main..HEAD 2>/dev/null || echo "?")"
      echo "Remote main:      @ ${remote}"
      if [[ "$current" == "$remote" ]]; then
        echo "Status:           up to date"
      else
        echo "Status:           ${behind} commit(s) behind, ${ahead} commit(s) ahead"
        echo
        echo "To update: git -C \"$GAMESTACK_DIR\" pull --ff-only"
      fi
    else
      echo "Status:           offline — couldn't fetch origin/main (skipping remote comparison)"
    fi
  else
    echo "Status:           no origin/main remote configured — skipping remote comparison"
  fi
  exit 0
fi

# Auto-detect host if not specified.
if [[ -z "$HOST" ]]; then
  if [[ -d "$HOME/.claude" ]]; then
    HOST="claude-code"
  else
    echo "error: no host detected." >&2
    echo "  Specify a host: --host <name>" >&2
    echo "  Supported in v0.1: claude-code" >&2
    exit 1
  fi
fi

if [[ "$HOST" == _* ]]; then
  echo "error: host names starting with underscore are reserved for internal use" >&2
  exit 1
fi

HOST_SCRIPT="$GAMESTACK_DIR/hosts/${HOST}.sh"
if [[ ! -f "$HOST_SCRIPT" ]]; then
  available=$(find "$GAMESTACK_DIR/hosts" -maxdepth 1 -name "*.sh" ! -name '_*' -exec basename {} .sh \; 2>/dev/null | sort | tr '\n' ' ')
  echo "error: unsupported host '$HOST'" >&2
  echo "  Available host scripts: ${available:-(none)}" >&2
  exit 1
fi

# Validate dependencies the host scripts assume are present.
for cmd in git ln find basename; do
  if ! command -v "$cmd" >/dev/null 2>&1; then
    echo "error: missing required command: $cmd" >&2
    exit 1
  fi
done

# CLIs need bun at runtime (skills don't). Warn at install time instead of letting the
# first CLI invocation die with exit 127.
if [[ $SELECT_CLI -eq 1 && "$MODE" == "install" ]] && ! command -v bun >/dev/null 2>&1; then
  echo "warning: bun not found — the gamestack-* CLIs need it at runtime." >&2
  echo "  Skills work without it. To use the CLIs:  brew install bun  (or see https://bun.sh)" >&2
fi

# Load the host's implementation.
# shellcheck source=/dev/null
source "$HOST_SCRIPT"

# Each host script must define: gamestack_install, gamestack_uninstall, gamestack_status.
for fn in gamestack_install gamestack_uninstall gamestack_status; do
  if ! declare -f "$fn" >/dev/null; then
    echo "error: host script $HOST_SCRIPT does not define $fn" >&2
    exit 1
  fi
done

if [[ $SELECT_CLI -eq 1 && -z "$CLI_DIR" ]]; then
  CLI_DIR="$(_gamestack_detect_cli_dir)"
fi
# Expand a leading ~ in CLI_DIR (bash doesn't tilde-expand inside variables).
if [[ -n "$CLI_DIR" && "$CLI_DIR" == "~"* ]]; then
  CLI_DIR="${HOME}${CLI_DIR:1}"
fi

# ---------------------------------------------------------------------------
# Hook install / uninstall / status helpers (Batch E1).
#
# Hook scripts live in bin/impl/hooks/. They're symlinked into CLI_DIR
# alongside the gamestack-* CLIs, and wired into the user's
# <project>/.claude/settings.local.json so Claude Code picks them up.
# ---------------------------------------------------------------------------

_gamestack_install_hooks() {
  local cli_dir="$1"
  local project_dir="$2"

  if [[ -z "$cli_dir" ]]; then
    echo "error: --hooks-for requires --cli-dir or a detected CLI dir" >&2
    return 1
  fi
  if ! command -v jq >/dev/null 2>&1; then
    echo "error: jq is required for --hooks-for (install: brew install jq)" >&2
    return 1
  fi

  mkdir -p "$cli_dir"
  for hook in gamestack-hook-session-start gamestack-hook-validate-state; do
    ln -sf "$GAMESTACK_DIR/bin/impl/hooks/$hook" "$cli_dir/$hook"
  done

  local settings="$project_dir/.claude/settings.local.json"
  mkdir -p "$(dirname "$settings")"
  [[ -f "$settings" ]] || echo '{}' > "$settings"

  local ss="$cli_dir/gamestack-hook-session-start"
  local vs="$cli_dir/gamestack-hook-validate-state"
  local tmp
  tmp="$(mktemp)"
  trap 'rm -f "$tmp"' RETURN

  jq --arg ss "$ss" --arg vs "$vs" '
    .hooks //= {} |
    .hooks.SessionStart = (
      (.hooks.SessionStart // [])
      | map(select((.hooks // []) | all(.command != $ss)))
      | . + [{
          "matcher": "startup|resume|clear",
          "hooks": [{"type": "command", "command": $ss}]
        }]
    ) |
    .hooks.PostToolUse = (
      (.hooks.PostToolUse // [])
      | map(select((.hooks // []) | all(.command != $vs)))
      | . + [{
          "matcher": "Edit|Write|MultiEdit",
          "hooks": [{"type": "command", "command": $vs}]
        }]
    )
  ' "$settings" > "$tmp"
  mv "$tmp" "$settings"

  echo "==> Installed hooks into $project_dir/.claude/settings.local.json"
  echo "    - gamestack-hook-session-start  → $ss"
  echo "    - gamestack-hook-validate-state → $vs"
}

_gamestack_uninstall_hooks() {
  local cli_dir="$1"
  local project_dir="$2"

  if [[ -z "$cli_dir" ]]; then
    echo "error: --hooks-for requires --cli-dir or a detected CLI dir" >&2
    return 1
  fi
  if ! command -v jq >/dev/null 2>&1; then
    echo "error: jq is required for --hooks-for uninstall (install: brew install jq)" >&2
    return 1
  fi

  rm -f "$cli_dir/gamestack-hook-session-start" "$cli_dir/gamestack-hook-validate-state"

  local settings="$project_dir/.claude/settings.local.json"
  if [[ ! -f "$settings" ]]; then
    echo "==> No $settings to clean."
    return 0
  fi

  local ss="$cli_dir/gamestack-hook-session-start"
  local vs="$cli_dir/gamestack-hook-validate-state"
  local tmp
  tmp="$(mktemp)"
  trap 'rm -f "$tmp"' RETURN

  jq --arg ss "$ss" --arg vs "$vs" '
    .hooks //= {} |
    if .hooks.SessionStart then
      .hooks.SessionStart |= map(select((.hooks // []) | all(.command != $ss)))
      | if (.hooks.SessionStart | length) == 0 then del(.hooks.SessionStart) else . end
    else . end
    | if .hooks.PostToolUse then
        .hooks.PostToolUse |= map(select((.hooks // []) | all(.command != $vs)))
        | if (.hooks.PostToolUse | length) == 0 then del(.hooks.PostToolUse) else . end
      else . end
    | if (.hooks | length) == 0 then del(.hooks) else . end
  ' "$settings" > "$tmp"
  mv "$tmp" "$settings"

  echo "==> Uninstalled hooks from $project_dir/.claude/settings.local.json"
}

_gamestack_status_hooks() {
  local cli_dir="$1"
  local project_dir="$2"

  echo "Hooks for $project_dir:"

  local hook target
  for hook in gamestack-hook-session-start gamestack-hook-validate-state; do
    target="$cli_dir/$hook"
    if [[ -L "$target" ]]; then
      printf '  %-32s installed (symlink: %s)\n' "$hook" "$target"
    else
      printf '  %-32s missing\n' "$hook"
    fi
  done

  local settings="$project_dir/.claude/settings.local.json"
  if [[ ! -f "$settings" ]]; then
    printf '  %-32s missing\n' "settings.local.json hooks"
    return 0
  fi

  if ! command -v jq >/dev/null 2>&1; then
    printf '  %-32s unknown (jq missing)\n' "settings.local.json hooks"
    return 0
  fi

  local has_ss has_pt
  has_ss="$(jq -r --arg ss "$cli_dir/gamestack-hook-session-start" '
    [.hooks.SessionStart // [] | .[] | .hooks[]?.command | select(. == $ss)] | length
  ' "$settings")"
  has_pt="$(jq -r --arg vs "$cli_dir/gamestack-hook-validate-state" '
    [.hooks.PostToolUse // [] | .[] | .hooks[]?.command | select(. == $vs)] | length
  ' "$settings")"

  local parts=()
  [[ "$has_ss" -gt 0 ]] && parts+=("SessionStart")
  [[ "$has_pt" -gt 0 ]] && parts+=("PostToolUse")

  if [[ ${#parts[@]} -eq 0 ]]; then
    printf '  %-32s missing\n' "settings.local.json hooks"
  else
    printf '  %-32s configured (%s)\n' "settings.local.json hooks" "$(IFS=, ; echo "${parts[*]}")"
  fi
}

case "$MODE" in
  install)
    # Compute the plan(s) for the selected scopes. Both are captured up front so
    # we can decide "nothing to do" before printing anything user-facing.
    skills_plan=""
    clis_plan=""
    if [[ $SELECT_SKILLS -eq 1 ]]; then
      skills_plan="$(_gamestack_plan_skills "$CLAUDE_SKILLS_DIR")"
    fi
    if [[ $SELECT_CLI -eq 1 && -n "$CLI_DIR" ]]; then
      clis_plan="$(_gamestack_plan_clis "$CLI_DIR")"
    fi

    if [[ -z "$skills_plan" && -z "$clis_plan" && -z "$HOOKS_FOR" ]]; then
      echo "==> Checking gamestack install for $HOST..."
      summary=""
      if [[ $SELECT_SKILLS -eq 1 ]]; then
        skill_count="$(_gamestack_list_skills | wc -l | tr -d '[:space:]')"
        summary="$skill_count skills"
      fi
      if [[ $SELECT_CLI -eq 1 ]]; then
        cli_count="$(_gamestack_list_clis | wc -l | tr -d '[:space:]')"
        if [[ -n "$summary" ]]; then
          summary="$summary and $cli_count CLIs"
        else
          summary="$cli_count CLIs"
        fi
      fi
      echo "✓ Already in sync — $summary all linked to this checkout."
      exit 0
    fi

    if [[ -n "$skills_plan" || -n "$clis_plan" ]]; then
      echo "==> gamestack would apply these changes for $HOST:"
      echo
      if [[ -n "$skills_plan" ]]; then
        printf '%s\n' "$skills_plan" | _gamestack_render_plan_section "Skills"
      fi
      if [[ -n "$clis_plan" ]]; then
        [[ -n "$skills_plan" ]] && echo
        printf '%s\n' "$clis_plan" | _gamestack_render_plan_section "CLIs"
      fi
      echo
      echo "==> Applying..."

      export GAMESTACK_QUIET_NOOPS=1
      if [[ $SELECT_SKILLS -eq 1 ]]; then
        gamestack_install
      fi
      if [[ $SELECT_CLI -eq 1 && -n "$CLI_DIR" ]]; then
        [[ $SELECT_SKILLS -eq 1 ]] && echo
        _gamestack_install_clis_to "$CLI_DIR"
      fi
    fi
    if [[ -n "$HOOKS_FOR" ]]; then
      [[ -n "$skills_plan" || -n "$clis_plan" ]] && echo
      _gamestack_install_hooks "$CLI_DIR" "$HOOKS_FOR"
    fi
    ;;
  uninstall)
    skills_plan=""
    clis_plan=""
    if [[ $SELECT_SKILLS -eq 1 ]]; then
      skills_plan="$(_gamestack_plan_uninstall_skills "$CLAUDE_SKILLS_DIR")"
    fi
    if [[ $SELECT_CLI -eq 1 && -n "$CLI_DIR" ]]; then
      clis_plan="$(_gamestack_plan_uninstall_clis "$CLI_DIR")"
    fi

    if [[ -z "$skills_plan" && -z "$clis_plan" && -z "$HOOKS_FOR" ]]; then
      echo "==> Checking gamestack install for $HOST..."
      echo "✓ Nothing to uninstall — no gamestack symlinks owned by this checkout."
      exit 0
    fi

    if [[ -n "$skills_plan" || -n "$clis_plan" ]]; then
      echo "==> gamestack would apply these changes for $HOST:"
      echo
      if [[ -n "$skills_plan" ]]; then
        printf '%s\n' "$skills_plan" | _gamestack_render_plan_section "Skills"
      fi
      if [[ -n "$clis_plan" ]]; then
        [[ -n "$skills_plan" ]] && echo
        printf '%s\n' "$clis_plan" | _gamestack_render_plan_section "CLIs"
      fi
      echo
      echo "==> Applying..."
    fi

    export GAMESTACK_QUIET_NOOPS=1
    if [[ $SELECT_SKILLS -eq 1 ]]; then
      gamestack_uninstall
    fi
    if [[ $SELECT_CLI -eq 1 && -n "$CLI_DIR" ]]; then
      [[ $SELECT_SKILLS -eq 1 ]] && echo
      _gamestack_uninstall_clis_to "$CLI_DIR"
    fi
    if [[ -n "$HOOKS_FOR" ]]; then
      [[ -n "$skills_plan" || -n "$clis_plan" ]] && echo
      _gamestack_uninstall_hooks "$CLI_DIR" "$HOOKS_FOR"
    fi
    ;;
  status)
    if [[ $SELECT_SKILLS -eq 1 ]]; then
      echo "==> gamestack status for $HOST:"
      gamestack_status
    fi
    if [[ $SELECT_CLI -eq 1 ]]; then
      [[ $SELECT_SKILLS -eq 1 ]] && echo
      echo "==> gamestack CLI status:"
      _gamestack_status_clis_to "$CLI_DIR"
    fi
    if [[ -n "$HOOKS_FOR" ]]; then
      echo
      echo "==> gamestack hooks status:"
      _gamestack_status_hooks "$CLI_DIR" "$HOOKS_FOR"
    fi
    ;;
esac
