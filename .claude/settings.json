{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read(./**)",
      "Edit(./**)",
      "Write(./**)",
      "Bash(./setup*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git show*)",
      "Bash(ls*)",
      "Bash(tree*)",
      "Bash(find*)",
      "Bash(grep*)",
      "Bash(rg*)"
    ],
    "deny": [
      "Read(./node_modules/**)",
      "Read(./dist/**)",
      "Read(./engines/**/Library/**)",
      "Read(./engines/**/.godot/**)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/bin/impl/skill-lint/validate-skill-change.sh"
          }
        ]
      }
    ]
  }
}
